{
  "manifest_version": 3,
  "name": "Context Auditor",
  "version": "1.0",
  "description": "AI Sports Fact-Checker",
  "permissions": [
    "contextMenus",
    "notifications"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}